	g++ -c  ../EasyGL/src/Application.cpp -O2 -W -Wall -I../EasyGL/include -I../glad/include 

glad.o :   
	gcc -c ../glad/src/glad.c -O2 -W -Wall -I../glad/include 

triangle : triangle.o libEasyGL.a glad.o 
	g++ -o $@ $^ -lglfw -ldl 

